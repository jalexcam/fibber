{
	"name": "jalexcam/fibber",
	"type": "library",
	"description": "Fibber is a PHP library that generates fake data.",
	"keywords": ["fibber","data", "jalexcam"],
	"license": "BSD-3-Clause",
	"authors": [
		{
			"name": "Alexander Campo",
			"email": "jalexcam@gmail.com"
		}
	],
	"require": {
		"php": "^8.3",
		"phpdocumentor/reflection-docblock": "^5.4",
		"psr/container": "^2.0"
	},
	"autoload": {
        "psr-4": {
            "Jalexcam\\Fibber\\": "src/"
        }
    },
    "extra": {
        "fibber": {
			"providers": [
				"Jalexcam\\Fibber\\FibberServiceProvider"
			]
	    }
	},
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}